      $('challengePrompt').innerHTML = `<div class="icon" aria-hidden="true">${e.icon}</div><div><p style="font-weight:800;color:var(--muted);margin-bottom:4px">${t('chooseFor')}</p><h2>${tx.title}</h2><p>${tx.clue}</p></div>`;
      const choices = makeOptions(id);
      const root = $('choices'); root.innerHTML='';
      choices.forEach(optId => {
        const opt = itemText(optId);
        const btn = document.createElement('button');
        btn.className = 'choice';
        btn.innerHTML = hardMode ? `${opt.display}<small>${t('exponent')}: 10${sup(events.find(e=>e.id===optId).exponent)}</small>` : `${opt.friendly}<small>${opt.display}</small>`;
        btn.onclick = () => answerChallenge(id, optId, btn);
        root.appendChild(btn);
      });
      $('challengeMessage').className = 'message warn';
      $('challengeMessage').textContent = hardMode ? t('hardDesc') : t('easyDesc');
    }

    function makeOptions(correctId){
      const correct = events.find(e=>e.id===correctId);
      const sorted = events.filter(e=>e.id!==correctId).sort((a,b)=>Math.abs(a.exponent-correct.exponent)-Math.abs(b.exponent-correct.exponent));
      const close = sorted.slice(0,2).map(e=>e.id);
      const far = shuffle(sorted.slice(2).map(e=>e.id)).slice(0,1);
      return shuffle([correctId, ...close, ...far]);
    }

    function answerChallenge(correctId, chosenId, btn){
      if(!challengeActive) return;
      const buttons = [...document.querySelectorAll('.choice')];
      buttons.forEach(b=>b.disabled=true);
      const correct = chosenId === correctId;
      if(correct){
        challengeScore += 100 + Math.max(0, remaining-45);
        btn.classList.add('correct');
        $('challengeMessage').className = 'message good';
        $('challengeMessage').textContent = interpolate(t('correctChallenge'), {note:itemText(correctId).note});
      } else {
        lives--;
        btn.classList.add('wrong');
        const answer = hardMode ? itemText(correctId).display : `${itemText(correctId).friendly} / ${itemText(correctId).display}`;
        buttons.forEach(b => { if(b.textContent.includes(itemText(correctId).display)) b.classList.add('correct'); });
        $('challengeMessage').className = 'message bad';
        $('challengeMessage').textContent = interpolate(t('wrongChallenge'), {answer, note:itemText(correctId).note});
      }
      score = Math.max(score, challengeScore); updateScore(); updateChallengeLabels();
      if(lives <= 0){ setTimeout(()=>endChallenge(t('gameOver')), 1300); }
      else setTimeout(nextRound, 1400);
    }

    function endChallenge(template){
      challengeActive = false;
      clearInterval(timer);
      $('challengeMessage').className = remaining <= 0 || lives <= 0 ? 'message bad' : 'message good';
      $('challengeMessage').textContent = interpolate(template, {score:challengeScore});
      $('startChallengeBtn').textContent = t('startChallenge');
      unlockLearningNotes();
      updateChallengeLabels();
    }

    document.querySelectorAll('[data-lang]').forEach(btn => btn.addEventListener('click', () => setLanguage(btn.dataset.lang)));
    $('exploreModeBtn').addEventListener('click', () => switchMode('explore'));
    $('challengeModeBtn').addEventListener('click', () => switchMode('challenge'));
    $('resetBtn').addEventListener('click', resetGame);
    $('shuffleBtn').addEventListener('click', shuffleGame);
    $('hintBtn').addEventListener('click', () => showMessage(t('hintText'),'warn'));
    $('startChallengeBtn').addEventListener('click', setupChallenge);
    $('hardToggle').addEventListener('click', () => { hardMode=!hardMode; $('hardToggle').setAttribute('aria-pressed', hardMode); $('hardToggle').textContent = hardMode ? t('hardModeOn') : t('hardModeOff'); if(challengeActive) $('challengeMessage').textContent = hardMode ? t('hardDesc') : t('easyDesc'); });

    setLanguage('en');
    challengeLimit = events.length * 9;
    remaining = challengeLimit;
    updateChallengeLabels();
  </script>
</body>
</html>
