      events.forEach(e => {
        const mark = document.createElement('div');
        mark.className = 'marker' + (matchedIds.has(e.id) ? '' : ' dim');
        mark.style.left = pos(Math.log10(e.seconds))+'%';
        mark.title = `${itemText(e.id).title}: ${itemText(e.id).display}`;
        mark.textContent = e.icon;
        axis.appendChild(mark);
      });
