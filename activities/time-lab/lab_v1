      ticks.forEach(exp => {
        const tick = document.createElement('div');
        tick.className = 'tick';
        tick.style.left = pos(exp)+'%';
        tick.innerHTML = `<span>10${sup(exp)}</span>`;
        axis.appendChild(tick);
