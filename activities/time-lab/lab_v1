    function selectCard(id){
      if(matchedIds.has(id)){ showMessage(t('cardAlready'),'warn'); return; }
      selectedCard = selectedCard === id ? null : id;
      renderCards();
      if(selectedCard) showMessage(interpolate(t('selectCard'), {name:itemText(id).title}), 'warn');
    }

    function tryMatch(cardId, slotId, slotEl){
      if(!cardId || matchedIds.has(slotId)) return;
      if(matchedIds.has(cardId)){ showMessage(t('cardAlready'),'warn'); return; }
      attempts++;
      if(cardId === slotId){
        matchedIds.add(cardId); correctCount++; streak++; score += 100 + Math.min(5, streak-1)*20;
        selectedCard = null;
        showMessage(`✓ ${itemText(cardId).title}: ${itemText(cardId).note}`, 'good');
        renderCards(); renderSlots(); renderAxis(); updateScore();
        if(matchedIds.size === events.length){ showMessage(t('matchedAll'), 'good'); unlockLearningNotes(); }
      } else {
        streak = 0; score = Math.max(0, score - 15);
        slotEl.classList.add('wrong');
        setTimeout(()=>slotEl.classList.remove('wrong'), 600);
        const cardExp = events.find(e=>e.id===cardId).exponent;
        const slotExp = events.find(e=>e.id===slotId).exponent;
        const clue = Math.abs(cardExp-slotExp) <= 1 ? t('close') : t('exponent');
        showMessage(`✗ ${t('tryAgain')} (${clue})`, 'bad');
        updateScore();
      }
    }

