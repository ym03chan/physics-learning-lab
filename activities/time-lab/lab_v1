    function renderAll(reshuffle=true){
      if(reshuffle || cardOrder.length===0){
        const ids = events.map(e=>e.id);
        cardOrder = shuffle(ids);
        slotOrder = shuffle(ids);
      }
      renderCards();
      renderSlots();
      renderAxis();
      renderFacts();
      renderKey();
      updateScore();
