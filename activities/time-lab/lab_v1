    function renderCards(){
      const root = $('cards');
      root.innerHTML = '';
      cardOrder.forEach(id => {
        const tx = itemText(id);
        const e = events.find(x=>x.id===id);
        const card = document.createElement('div');
        card.className = 'card' + (matchedIds.has(id) ? ' matched' : '') + (selectedCard===id ? ' selected' : '');
        card.setAttribute('draggable', !matchedIds.has(id));
        card.setAttribute('tabindex','0');
        card.dataset.id = id;
        card.innerHTML = `<div class="icon" aria-hidden="true">${e.icon}</div><div><div class="card-title">${tx.title}</div><div class="card-clue">${tx.clue}</div></div>`;
        card.addEventListener('dragstart', ev => { ev.dataTransfer.setData('text/plain', id); card.classList.add('dragging'); });
        card.addEventListener('dragend', () => card.classList.remove('dragging'));
        card.addEventListener('click', () => selectCard(id));
        card.addEventListener('keydown', ev => { if(ev.key==='Enter' || ev.key===' '){ev.preventDefault();selectCard(id);} });
        root.appendChild(card);
      });
    }

    function renderSlots(){
      const root = $('slots');
      root.innerHTML = '';
      slotOrder.forEach(id => {
        const tx = itemText(id);
        const already = matchedIds.has(id);
        const slot = document.createElement('div');
        slot.className = 'slot' + (already ? ' correct locked' : '');
        slot.dataset.id = id;
        slot.setAttribute('tabindex','0');
        slot.innerHTML = `
          <div class="duration"><b>${tx.friendly}</b><small>${tx.display}</small></div>
          <div class="droptext">${already ? t('correct') : t('dropHere')}</div>
          <div class="slotBody">${already ? placedHTML(id) : ''}</div>
        `;
        slot.addEventListener('dragover', ev => { ev.preventDefault(); slot.classList.add('over'); });
        slot.addEventListener('dragleave', () => slot.classList.remove('over'));
        slot.addEventListener('drop', ev => { ev.preventDefault(); slot.classList.remove('over'); tryMatch(ev.dataTransfer.getData('text/plain'), id, slot); });
        slot.addEventListener('click', () => { if(selectedCard) tryMatch(selectedCard, id, slot); });
        slot.addEventListener('keydown', ev => { if((ev.key==='Enter'||ev.key===' ') && selectedCard){ev.preventDefault();tryMatch(selectedCard,id,slot);} });
        root.appendChild(slot);
      });
    }

    function placedHTML(id){
      const tx = itemText(id); const e = events.find(x=>x.id===id);
      return `<div class="placed"><div class="icon" aria-hidden="true">${e.icon}</div><div><b>${tx.title}</b><div class="card-clue">${t('placed')}</div></div></div><div class="status good">✓ ${t('correct')}</div>`;
