<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hong Kong Time Quest: Measurement Matching Game</title>
  <style>
    :root{
      --bg:#f7f8fb;
      --panel:#ffffff;
      --ink:#172033;
      --muted:#5c667a;
      --accent:#ff8a00;
      --accent-2:#2d7ff9;
      --good:#127c45;
      --bad:#b42318;
      --warn:#946200;
      --line:#d8deea;
      --shadow:0 12px 30px rgba(23,32,51,.12);
      --radius:18px;
      --focus:0 0 0 4px rgba(45,127,249,.22);
    }
    *{box-sizing:border-box}
    html,body{margin:0;min-height:100%;background:radial-gradient(circle at top left,#fff4dc 0,#f7f8fb 38%,#eef3ff 100%);color:var(--ink);font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;}
    body{padding:16px;}
    button,input{font:inherit}
    button{cursor:pointer}
    .app{max-width:1220px;margin:0 auto;}
    .topbar{position:sticky;top:0;z-index:10;display:grid;grid-template-columns:1fr auto;gap:12px;align-items:center;padding:12px;margin:-16px -16px 16px;background:rgba(247,248,251,.88);backdrop-filter:blur(12px);border-bottom:1px solid rgba(216,222,234,.7)}
    .brand{display:flex;gap:12px;align-items:center;min-width:0}
    .logo{width:48px;height:48px;border-radius:15px;background:linear-gradient(135deg,var(--accent),#ffd36e);display:grid;place-items:center;box-shadow:var(--shadow);font-size:28px;flex:0 0 auto;}
    h1{font-size:clamp(1.3rem,2.5vw,2.15rem);line-height:1.05;margin:0;}
    .subtitle{margin:4px 0 0;color:var(--muted);font-size:.98rem}
    .tabs,.actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;align-items:center}
    .tab,.btn{border:1px solid var(--line);background:var(--panel);color:var(--ink);border-radius:999px;padding:9px 13px;font-weight:700;box-shadow:0 2px 8px rgba(23,32,51,.05)}
    .tab[aria-selected="true"],.btn.primary{background:var(--ink);color:white;border-color:var(--ink)}
    .btn.orange{background:var(--accent);border-color:var(--accent);color:#141414}
    .btn.ghost{background:transparent}
    .btn.small{padding:7px 10px;font-size:.9rem}
    button:focus-visible,.card:focus-visible,.slot:focus-visible,.choice:focus-visible{outline:none;box-shadow:var(--focus)}
    .hero{display:grid;grid-template-columns:minmax(0,1.2fr) minmax(280px,.8fr);gap:16px;margin-bottom:16px}
    .panel{background:rgba(255,255,255,.92);border:1px solid rgba(216,222,234,.95);border-radius:var(--radius);box-shadow:var(--shadow);padding:18px;}
    .panel h2,.panel h3{margin:0 0 10px}
    .panel p{margin:8px 0;color:var(--muted);line-height:1.5}
    .pillrow{display:flex;flex-wrap:wrap;gap:8px;margin-top:12px}
    .pill{border:1px solid var(--line);border-radius:999px;padding:6px 10px;background:#fbfcff;color:#3d4659;font-size:.92rem}
    .scoreboard{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
    .scorebox{background:#f8fafc;border:1px solid var(--line);border-radius:14px;padding:12px;text-align:center}
    .scorebox b{display:block;font-size:1.35rem}.scorebox span{color:var(--muted);font-size:.85rem}
    .modebar{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;align-items:center;justify-content:space-between}
    .mode-left,.mode-right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .game{display:grid;grid-template-columns:340px minmax(0,1fr);gap:16px;align-items:start}
    .tray{position:sticky;top:92px;max-height:calc(100vh - 110px);overflow:auto}
    .tray h2,.board h2{font-size:1.05rem;margin:0 0 10px}
    .hintline{font-size:.92rem;color:var(--muted);line-height:1.4;margin-bottom:12px}
    .cards{display:grid;gap:10px}
    .card{display:grid;grid-template-columns:48px 1fr;gap:10px;align-items:center;padding:10px;border:2px solid var(--line);border-radius:16px;background:white;box-shadow:0 4px 12px rgba(23,32,51,.07);user-select:none;min-height:70px}
    .card:hover{transform:translateY(-1px)}
    .card.dragging{opacity:.55}.card.matched{opacity:.46;background:#f1f5f9}.card.selected{border-color:var(--accent-2);box-shadow:var(--focus)}
    .icon{width:46px;height:46px;border-radius:14px;display:grid;place-items:center;background:#fff3df;border:1px solid #ffd08b;font-size:28px}
    .card-title{font-weight:800}.card-clue{font-size:.82rem;color:var(--muted);margin-top:2px}
    .board{min-width:0}.slots{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
    .slot{position:relative;min-height:138px;padding:12px;border:2px dashed #b8c2d5;border-radius:18px;background:linear-gradient(180deg,#ffffff,#f8fafc);transition:.15s;}
    .slot.over{border-color:var(--accent-2);background:#edf5ff}.slot.correct{border-style:solid;border-color:var(--good);background:#effaf4}.slot.wrong{border-style:solid;border-color:var(--bad);background:#fff1ef}.slot.locked{border-style:solid;border-color:#9aa7bb;background:#f8fafc}.duration{display:flex;align-items:baseline;justify-content:space-between;gap:8px;border-bottom:1px solid var(--line);padding-bottom:8px;margin-bottom:8px}.duration b{font-size:1.04rem}.duration small{color:var(--muted);white-space:nowrap}.droptext{color:var(--muted);font-size:.92rem;line-height:1.35}.placed{margin-top:8px;display:grid;grid-template-columns:42px 1fr;gap:9px;align-items:center;background:white;border:1px solid var(--line);border-radius:14px;padding:8px}.placed .icon{width:38px;height:38px;font-size:23px}.status{margin-top:8px;font-weight:800;font-size:.93rem}.status.good{color:var(--good)}.status.bad{color:var(--bad)}
    .timeline{position:relative;margin-top:16px;padding:18px 10px 46px;border-radius:18px;background:rgba(255,255,255,.9);border:1px solid var(--line);overflow:hidden}.axis-title{display:flex;justify-content:space-between;gap:8px;color:var(--muted);font-size:.88rem;margin-bottom:12px}.axis{position:relative;height:36px;border-radius:999px;background:linear-gradient(90deg,#ffd16f,#ffac2d,#ff8a00);box-shadow:inset 0 1px 2px rgba(0,0,0,.12)}.tick{position:absolute;top:0;height:36px;width:1px;background:rgba(0,0,0,.28)}.tick span{position:absolute;top:38px;transform:translateX(-50%);font-weight:700;font-size:.8rem;white-space:nowrap}.marker{position:absolute;top:13px;transform:translate(-50%,-50%);width:32px;height:32px;border-radius:50%;border:3px solid white;background:var(--ink);color:white;display:grid;place-items:center;font-size:18px;box-shadow:0 4px 10px rgba(0,0,0,.2)}.marker.dim{opacity:.22}.legend{display:flex;justify-content:space-between;margin-top:24px;font-size:.85rem;color:var(--muted)}
    .message{margin-top:12px;border-radius:16px;padding:12px 14px;border:1px solid var(--line);background:#fbfcff;color:#334155;line-height:1.45}.message.good{border-color:#a7dfbe;background:#f0fff5}.message.bad{border-color:#ffb4aa;background:#fff5f3}.message.warn{border-color:#f9d47b;background:#fff9e9}
    .challenge-wrap{display:none}.challenge-card{display:grid;gap:16px}.big-event{display:grid;grid-template-columns:76px 1fr;gap:14px;align-items:center;background:#f8fafc;border:1px solid var(--line);border-radius:20px;padding:16px}.big-event .icon{width:70px;height:70px;font-size:42px;border-radius:22px}.big-event h2{margin:0 0 4px}.big-event p{margin:0;color:var(--muted)}.choices{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}.choice{text-align:left;border:2px solid var(--line);border-radius:18px;background:white;padding:16px;min-height:84px;font-weight:800}.choice small{display:block;margin-top:4px;color:var(--muted);font-weight:600}.choice.correct{border-color:var(--good);background:#effaf4}.choice.wrong{border-color:var(--bad);background:#fff1ef}.meter{height:12px;background:#eef2f7;border-radius:999px;overflow:hidden}.meter div{height:100%;background:var(--accent);width:100%;transition:width .2s}.facts{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;margin-top:16px}.fact{border:1px solid var(--line);border-radius:16px;background:#fbfcff;padding:12px}.fact b{display:block;margin-bottom:4px}.fact span{color:var(--muted);font-size:.92rem;line-height:1.35}.hidden{display:none!important}details{margin-top:12px}summary{cursor:pointer;font-weight:800;color:#2c3547}.keygrid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px;margin-top:10px}.keyitem{padding:9px;border:1px solid var(--line);border-radius:12px;background:#fff}.keyitem b{display:block}.keyitem span{color:var(--muted);font-size:.88rem}
    @media (max-width: 980px){.hero,.game{grid-template-columns:1fr}.tray{position:relative;top:0;max-height:none}.topbar{grid-template-columns:1fr}.tabs,.actions{justify-content:flex-start}.scoreboard{grid-template-columns:repeat(2,1fr)}.slots,.choices,.facts,.keygrid{grid-template-columns:1fr}.modebar{align-items:flex-start}.mode-left,.mode-right{width:100%}}
    @media (max-width: 560px){body{padding:10px}.topbar{margin:-10px -10px 12px}.panel{padding:14px}.card{grid-template-columns:42px 1fr}.icon{width:40px;height:40px;font-size:24px}.slot{min-height:126px}.duration{display:block}.duration small{display:block;margin-top:2px}.legend{display:block;line-height:1.6}.axis{height:30px}.tick{height:30px}.tick span{font-size:.7rem}.marker{width:28px;height:28px;font-size:16px}.subtitle{font-size:.9rem}}
    @media (prefers-reduced-motion: reduce){*{transition:none!important;animation:none!important}.card:hover{transform:none}}
  </style>
</head>
<body>
  <div class="app">
    <header class="topbar" aria-label="Top controls">
      <div class="brand">
        <div class="logo" aria-hidden="true">⏱️</div>
        <div>
          <h1 data-i18n="appTitle">Hong Kong Time Quest: Measurement Match</h1>
          <p class="subtitle" data-i18n="tagline">Match Hong Kong-flavoured science examples to seconds, powers of ten, and real units.</p>
        </div>
      </div>
      <div class="tabs" role="tablist" aria-label="Language">
        <button class="tab" data-lang="en" aria-selected="true">English</button>
        <button class="tab" data-lang="zh" aria-selected="false">中文</button>
      </div>
    </header>

    <section class="hero">
      <div class="panel">
        <h2 data-i18n="introTitle">Mission</h2>
        <p data-i18n="introBody">Match each event to its approximate duration. The examples are deliberately not copied from the textbook and connect Hong Kong, Chinese culture, science, and technology.</p>
        <div class="pillrow" aria-label="Learning principles">
          <span class="pill" data-i18n="principle1">C: close distractors</span>
          <span class="pill" data-i18n="principle2">U: unit conversion anchors</span>
          <span class="pill" data-i18n="principle3">R: Hong Kong + Chinese context</span>
          <span class="pill" data-i18n="principle4">I: science across 30 powers of ten</span>
        </div>
        <details>
          <summary data-i18n="teacherNotesTitle">CURI design idea</summary>
          <p data-i18n="teacherNotesBody">Approximate values are intentional; the learning target is scale sense, not memorising one exact number.</p>
        </details>
      </div>
      <div class="panel">
        <div class="scoreboard" aria-live="polite">
          <div class="scorebox"><b id="score">0</b><span data-i18n="score">Score</span></div>
          <div class="scorebox"><b id="matched">0/10</b><span data-i18n="matched">Matched</span></div>
          <div class="scorebox"><b id="streak">0</b><span data-i18n="streak">Streak</span></div>
          <div class="scorebox"><b id="accuracy">–</b><span data-i18n="accuracy">Accuracy</span></div>
        </div>
      </div>
    </section>

    <div class="modebar">
      <div class="mode-left" role="tablist" aria-label="Game mode">
        <button class="tab" id="exploreModeBtn" aria-selected="true" data-i18n="exploreMode">Explore mode</button>
        <button class="tab" id="challengeModeBtn" aria-selected="false" data-i18n="challengeMode">Challenge mode</button>
      </div>
      <div class="mode-right">
        <button class="btn small" id="hintBtn" data-i18n="hint">Hint</button>
        <button class="btn small" id="shuffleBtn" data-i18n="shuffle">Shuffle</button>
        <button class="btn small ghost" id="resetBtn" data-i18n="reset">Reset</button>
      </div>
    </div>

    <main class="game" id="exploreWrap">
      <section class="panel tray" aria-labelledby="cardsTitle">
        <h2 id="cardsTitle" data-i18n="eventCards">Event cards</h2>
        <div class="hintline" data-i18n="dragHelp">Drag a card to a duration, or tap a card then tap a duration box.</div>
        <div class="cards" id="cards"></div>
      </section>
      <section class="board" aria-labelledby="boardTitle">
        <div class="panel">
          <h2 id="boardTitle" data-i18n="durationSlots">Duration slots</h2>
          <div class="hintline" data-i18n="boardHelp">Approximate values are intentional. Focus on unit conversion and order of magnitude.</div>
          <div class="slots" id="slots"></div>
          <div id="message" class="message warn" data-i18n="startMessage">Start by matching the extremes: the fastest event and the slowest event.</div>
        </div>
        <section class="timeline" aria-label="Logarithmic time ruler">
          <div class="axis-title"><span data-i18n="timelineTitle">Logarithmic time ruler</span><span data-i18n="timelineRight">time / s</span></div>
          <div class="axis" id="axis"></div>
          <div class="legend"><span>10⁻¹³ s</span><span>10¹⁷ s</span></div>
        </section>
      </section>
    </main>

    <section class="challenge-wrap" id="challengeWrap">
      <div class="panel challenge-card">
        <div class="modebar" style="margin:0">
          <div class="mode-left">
            <button class="btn orange" id="startChallengeBtn" data-i18n="startChallenge">Start challenge</button>
            <button class="btn" id="hardToggle" aria-pressed="false" data-i18n="hardMode">Hard mode: off</button>
          </div>
          <div class="mode-right">
            <span class="pill"><span data-i18n="round">Round</span>: <b id="roundLabel">0/10</b></span>
            <span class="pill"><span data-i18n="lives">Lives</span>: <b id="livesLabel">3</b></span>
            <span class="pill"><span data-i18n="timer">Timer</span>: <b id="timeLabel">90</b>s</span>
          </div>
        </div>
        <div class="meter" aria-hidden="true"><div id="timeBar"></div></div>
        <div class="big-event" id="challengePrompt">
          <div class="icon">🎯</div>
          <div>
            <h2 data-i18n="challengePromptTitle">Ready for the clock run?</h2>
            <p data-i18n="challengePromptBody">You will get 10 rounds. Choose the matching duration before time runs out. Wrong answers cost a life; close distractors are deliberately included.</p>
          </div>
        </div>
        <div class="choices" id="choices"></div>
        <div id="challengeMessage" class="message warn" data-i18n="challengeStartMessage">Press Start challenge when you are ready.</div>
      </div>
      <section class="facts hidden" id="facts"></section>
    </section>

    <section class="panel hidden" id="answerPanel" style="margin-top:16px">
      <details>
        <summary data-i18n="answerKey">Post-game answer key and conversion notes</summary>
        <div class="keygrid" id="keygrid"></div>
      </details>
    </section>
  </div>

  <script>
    const translations = {
      "en": {
            "appTitle": "Hong Kong Time Quest: Measurement Match",
